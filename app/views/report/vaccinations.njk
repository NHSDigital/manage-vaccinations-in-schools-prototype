{% from "_macros/report-search.njk" import appReportSearch with context %}
{% from "report/_navigation.njk" import reportNavigation with context %}

{% extends "_layouts/form.njk" %}

{% set gridColumns = "full" %}
{% set hideConfirmButton = true %}
{% set title = __("report.list.title") + " – " + __("report.vaccinations.title") %}

{% block form %}
  {{ super() }}

  {{ reportNavigation({
    view: "vaccinations"
  }) }}

  <div class="nhsuk-grid-row">
    <app-auto-submit class="nhsuk-grid-column-one-quarter">
      {{ appReportSearch({
        clear: "/reports/vaccinations"
      }) }}
    </app-auto-submit>

    <div class="nhsuk-grid-column-three-quarters">
      <div class="nhsuk-grid-row nhsuk-card-group">
        <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
          {{ appDataCard({
            heading: "Cohort",
            headingLevel: 3,
            headingSize: "xs",
            colour: "blue",
            compact: true,
            data: vaccinations.length,
            meta: "children"
          }) }}
        </div>
        <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
          {{ appDataCard({
            heading: "Not vaccinated",
            headingLevel: 3,
            headingSize: "xs",
            colour: "red",
            compact: true,
            data: (((vaccinations | rejectattr("given") | length) / vaccinations.length * 100) | round(2) or 0) + "%",
            meta: vaccinations | rejectattr("given") | length + " children"
          }) }}
        </div>
        <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
          {{ appDataCard({
            heading: "Vaccinated",
            headingLevel: 3,
            headingSize: "xs",
            colour: "green",
            compact: true,
            data: (((vaccinations | selectattr("given") | length) / vaccinations.length * 100) | round(2) or 0) + "%",
            meta: vaccinations | selectattr("given") | length + " children"
          }) }}
        </div>
      </div>

      {{ table({
        responsive: true,
        card: {
          feature: true,
          heading: __("report.vaccinations.team", data.team.ods),
          headingLevel: 2
        },
        head: [
          {
            text: "Month"
          },
          {
            text: "School",
            format: "numeric"
          },
          {
            text: "Community",
            format: "numeric"
          }
        ],
        rows: [
          [
            {
              text: "November 2025"
            },
            {
              text: "14",
              format: "numeric"
            },
            {
              text: "0",
              format: "numeric"
            }
          ],
          [
            {
              text: "December 2025"
            },
            {
              text: "3",
              format: "numeric"
            },
            {
              text: "0",
              format: "numeric"
            }
          ],
          [
            {
              text: "January 2026"
            },
            {
              text: "3",
              format: "numeric"
            },
            {
              text: "0",
              format: "numeric"
            }
          ],
          [
            {
              text: "February 2026"
            },
            {
              text: "4",
              format: "numeric"
            },
            {
              text: "0",
              format: "numeric"
            }
          ],
          [
            {
              html: "<b>Total</b>"
            },
            {
              html: "<b>23</b>",
              format: "numeric"
            },
            {
              html: "<b>0</b>",
              format: "numeric"
            }
          ]
        ]
      }) }}

      {{ __("report.list.updated", today) | nhsukMarkdown }}
    </div>
  </div>
{% endblock %}
