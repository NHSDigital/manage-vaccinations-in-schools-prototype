{% from "_macros/report-search.njk" import appReportSearch with context %}
{% from "report/_navigation.njk" import reportNavigation with context %}

{% extends "_layouts/form.njk" %}

{% set gridColumns = "full" %}
{% set hideConfirmButton = true %}
{% set title = __("report.list.title") + " – " + __("report.local-authorities.title") %}

{% block form %}
  {{ super() }}

  {{ reportNavigation({
    view: "local-authorities"
  }) }}

  <div class="nhsuk-grid-row">
    <app-auto-submit class="nhsuk-grid-column-one-quarter">
      {{ appReportSearch({
        clear: "/reports/local-authorities"
      }) }}
    </app-auto-submit>

    <div class="nhsuk-grid-column-three-quarters">
      {{ __("report.list.updated", today) | nhsukMarkdown }}
    </div>
  </div>
{% endblock %}
