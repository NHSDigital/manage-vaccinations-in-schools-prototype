{% set summary = patientProgramme.scheduleSummary %}

{% call card({
  heading: __("patientProgramme.vaccinationRecord.label"),
  headingLevel: 3
}) %}
  {{ patientProgramme.formatted.statusWithNotes | nhsukMarkdown }}

  <p class="nhsuk-body">
    {{ __mf("patientProgramme.vaccinationRecord.dosesComplete", {
      complete: summary.dosesComplete,
      needed: summary.dosesNeeded
    }) }}
  </p>

  {% set rows = [] %}

  {% for ignored in summary.ignoredDoses %}
    {% set ignoredLabelHtml %}
      <span>
        {{- tag({
          text: __("patientProgramme.vaccinationRecord.ignored.label"),
          classes: "nhsuk-tag--grey"
        }) -}}
        <br>
        <span class="nhsuk-u-secondary-text-colour nhsuk-u-font-size-16">{{ ignored.reason }}</span>
      </span>
    {% endset %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        html: ignoredLabelHtml
      },
      {
        header: __("vaccination.createdAt.label"),
        html: ignored.vaccination.link.createdAt
      },
      {
        header: __("vaccination.age.label"),
        text: patient.dob | age(at=ignored.vaccination.createdAt)
      },
      {
        header: __("vaccination.source.label"),
        text: ignored.vaccination.source
      }
    ]) %}
  {% endfor %}

  {% for valid in summary.validDoses %}
    {% set validDoseHtml %}
      {{ __mf("patientProgramme.vaccinationRecord.dose.number", {
        sequence: valid.sequence
      }) }}
      {% if valid.vaccination.vaccine.type %}
        <br>
        <span class="nhsuk-u-secondary-text-colour nhsuk-u-font-size-16">{{ valid.vaccination.vaccine.type }}</span>
      {% endif %}
    {% endset %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        html: validDoseHtml
      },
      {
        header: __("vaccination.createdAt.label"),
        html: valid.vaccination.link.createdAt
      },
      {
        header: __("vaccination.age.label"),
        text: patient.dob | age(at=valid.vaccination.createdAt)
      },
      {
        header: __("vaccination.source.label"),
        text: valid.vaccination.source
      }
    ]) %}
  {% endfor %}

  {% set firstEmptySequence = summary.validDoses.length + 1 %}
  {% for sequence in range(firstEmptySequence, summary.dosesNeeded + 1) %}
    {% set isFirstEmpty = sequence == firstEmptySequence %}
    {% set dateText = "—" %}
    {% if isFirstEmpty and summary.nextEligibleFromFormatted %}
      {% set dateText = __mf("patientProgramme.vaccinationRecord.eligibleFrom", {
        date: summary.nextEligibleFromFormatted
      }) %}
    {% endif %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        text: __mf("patientProgramme.vaccinationRecord.dose.number", {
          sequence: sequence
        })
      },
      {
        header: __("vaccination.createdAt.label"),
        text: dateText
      },
      {
        header: __("vaccination.age.label"),
        text: "—"
      },
      {
        header: __("vaccination.source.label"),
        text: "—"
      }
    ]) %}
  {% endfor %}

  {{ table({
    id: "vaccination-record",
    responsive: true,
    head: [
      { text: __("patientProgramme.vaccinationRecord.dose.label") },
      { text: __("vaccination.createdAt.label") },
      { text: __("vaccination.age.label") },
      { text: __("vaccination.source.label") }
    ],
    rows: rows
  }) if rows.length }}
{% endcall %}
