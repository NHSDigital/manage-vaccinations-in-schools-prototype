{% extends "_layouts/form.njk" %}

{% set title = __("patient.nhsn.title") %}

{% block form %}
  {{ input({
    label: {
      html: appHeading({
        caption: patient.fullName,
        title: title
      })
    },
    code: true,
    width: 10,
    value: "" if patient.hasMissingNhsNumber else patient.nhsn,
    decorate: "patient.nhsn"
  }) }}
{% endblock %}
