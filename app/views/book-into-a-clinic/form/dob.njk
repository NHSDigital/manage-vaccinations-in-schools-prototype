{% extends "_layouts/form.njk" %}

{% set title = __("clinicBooking.dob.title", firstName) %}

{% block form %}
  {{ dateInput({
    fieldset: {
      legend: {
        html: appHeading({
          classes: "nhsuk-fieldset__legend--l",
          title: title,
          caption: __("clinicBooking.appointment.caption", fullName) if transaction.childCount > 1
        })
      }
    },
    hint: { text: __("clinicBooking.dob.hint") },
    decorate: "clinicAppointment.unmatchedDob_"
  }) }}
{% endblock %}
