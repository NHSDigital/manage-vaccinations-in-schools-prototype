{% extends "_layouts/form.njk" %}

{% set confirmButtonText = __("clinicBooking.check-answers.confirm") %}
{% set title = __("clinicBooking.check-answers.title") %}
{% set gridColumns = "three-quarters" %}
{% macro editPath(view) -%}
  {{- view }}?referrer={{ clinicBooking.bookingUri }}/new/check-answers
{%- endmacro %}

{% block form %}
  {{ appHeading({
    title: title
  }) }}

  {{ appHeading({
    title: "Child details",
    level: 2,
    size: "m"
  }) }}

  <dl class="nhsuk-summary-list">
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Name
      </dt>
      <dd class="nhsuk-summary-list__value">
        Billie Rushton
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> name</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Date of birth
      </dt>
      <dd class="nhsuk-summary-list__value">
        27 March 2012
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> date of birth</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Your relationship
      </dt>
      <dd class="nhsuk-summary-list__value">
        Mum
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> your relationship</span></a>
      </dd>
    </div>
  </dl>

  <h2 class="nhsuk-heading-m">
    Appointment details
  </h2>

  <dl class="nhsuk-summary-list">
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Clinic location
      </dt>
      <dd class="nhsuk-summary-list__value">
        Killingworth Library, White Swan Centre, Killingworth, NE12 6SS
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> clinic location</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Date
      </dt>
      <dd class="nhsuk-summary-list__value">
        Wednesday 25 February
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> clinic date</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Time
      </dt>
      <dd class="nhsuk-summary-list__value">
        9:30am
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> time</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Vaccinations
      </dt>
      <dd class="nhsuk-summary-list__value">
        HPV, MenACWY, Td/IPV
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> vaccinations</span></a>
      </dd>
    </div>
  </dl>

  <h2 class="nhsuk-heading-m">
    Your details
  </h2>

  <dl class="nhsuk-summary-list">
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Name
      </dt>
      <dd class="nhsuk-summary-list__value">
        Ellie Rushton
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> your name</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Email
      </dt>
      <dd class="nhsuk-summary-list__value">
        ellier1982@outlook.com
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> your email address</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Phone number
      </dt>
      <dd class="nhsuk-summary-list__value">
        07787 123 456
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> your phone number</span></a>
      </dd>
    </div>
    <div class="nhsuk-summary-list__row">
      <dt class="nhsuk-summary-list__key">
        Receive confirmation and reminder text messages?
      </dt>
      <dd class="nhsuk-summary-list__value">
        Yes
      </dd>
      <dd class="nhsuk-summary-list__actions">
        <a class="nhsuk-link" href="#">Change<span class="nhsuk-u-visually-hidden"> your contact preferences</span></a>
      </dd>
    </div>
  </dl>
{% endblock %}
