{% extends "_layouts/form.njk" %}

{% set title = __("session.reminderWeeks.title") %}

{% block form %}
  {{ input({
    label: {
      classes: "nhsuk-label--l",
      html: appHeading({
        caption: session.location.name if type == "edit",
        title: title
      })
    },
    hint: { text: __("session.reminderWeeks.hint") },
    suffix: "weeks",
    width: 2,
    decorate: "session.reminderWeeks"
  }) }}
{% endblock %}
