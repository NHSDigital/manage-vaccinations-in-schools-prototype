{{ appHeading({
  title: "Appointments",
  level: 3,
  size: "m"
}) }}

<div class="nhsuk-grid-row nhsuk-card-group">
  {% set columnWidth = "quarter" %}

  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: "Total appointments",
      headingLevel: 4,
      compact: true,
      data: session.totalAppointmentCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: "Available appointments",
      headingLevel: 4,
      colour: "white" if session.availableAppointmentCount > 10 else ("orange" if session.availableAppointmentCount > 0 else "red"),
      compact: true,
      data: session.availableAppointmentCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: "Vaccinators (max.)" if session.hasVariableVaccinatorCounts else "Vaccinators",
      headingLevel: 4,
      compact: true,
      data: session.maximumVaccinatorCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: "Days left to book",
      headingLevel: 4,
      colour: "orange" if session.daysLeftToBook < 7 and session.daysLeftToBook > 0,
      compact: true,
      data: session.daysLeftToBook,
      href: session.uri + "/edit"
    }) }}
  </div>
  {% for programme in session.programmes %}
    <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
      {{ appDataCard({
        heading: programme.type + " appointments",
        headingLevel: 4,
        colour: "green",
        compact: true,
        data: "12",
        href: session.uri + "/report?programme_id=" + programme.id
      }) }}
    </div>
  {% endfor %}
</div>
