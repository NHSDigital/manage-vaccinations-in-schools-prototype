{% extends "_layouts/form.njk" %}

{% set title = __("pds.start.title") %}

{% block form %}
  {{ radios({
    fieldset: {
      legend: {
        text: title,
        size: "l"
      }
    },
    items: [{
      text: "Yes",
      value: true,
      conditional: {
        html: input({
          label: { text: __("pds.nhsn.label") },
          hint: { text: __("pds.nhsn.hint") },
          code: true,
          width: 10,
          name: "nhsn"
        })
      }
    }, {
      text: "No",
      value: false
    }],
    decorate: "hasNhsNumber"
  }) }}
{% endblock %}
